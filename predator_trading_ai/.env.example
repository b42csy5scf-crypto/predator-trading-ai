TWITTER_BEARER_TOKEN=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

MAX_RISK_PER_TRADE_PCT=1.0
MAX_DAILY_LOSS_PCT=3.0
MAX_OPEN_TRADES=3
MIN_CONFIDENCE=60
MIN_LIQUIDITY_SCORE=60
MAX_SPREAD_PCT=2.0
MIN_RISK_REWARD=1.5
WATCHLIST=SPY,QQQ
LOOP_INTERVAL_SECONDS=300
PAPER_ACCOUNT_EQUITY=100000
